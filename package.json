{
  "name": "smartguard-desktop",
  "version": "1.0.0",
  "main": "electron.js",
  "scripts": {
    "start": "node ./node_modules/electron/cli.js .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "asar": false,
    "appId": "com.smartguard.app",
    "productName": "SmartGuard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "smartguard-ui/build/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "smartguard-service/dist/main.exe",
        "to": "backend/main.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SmartGuard"
    }
  }
}
